{
  "name": "browser-control-agent",
  "version": "0.1.0",
  "description": "AI browser control agent — NL command drives a real Chromium browser through multi-step web flows",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "postinstall": "playwright install chromium",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx/esm --test"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "3.4.0",
    "playwright": "1.60.0",
    "dotenv": "^17",
    "zod": "^3.25.76",
    "ws": "^8.21.0",
    "chalk": "^5"
  },
  "devDependencies": {
    "typescript": "^5.9",
    "tsx": "^4.22",
    "@types/node": "^22",
    "@types/ws": "^8",
    "@playwright/test": "1.60.0"
  }
}
